# ── Google AI ──────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-studio-key-here
LLM_MODEL=gemini-2.5-flash-preview-05-20
EMBEDDING_MODEL=gemini-embedding-001

# ── Database ───────────────────────────────────────────────────
# For local dev without Docker:
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb

# ── Auth (change these secrets in production!) ─────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Vector Store ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Retrieval ──────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=12
RETRIEVAL_SCORE_THRESHOLD=0.35
RETRIEVAL_DIVERSITY_THRESHOLD=0.85
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIES=3

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
